{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/public/scripts",
    "rootDir": "./src/scripts",
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "resolveJsonModule": false,
    "isolatedModules": false
  },
  "include": ["src/scripts/**/*", "src/**/*.d.ts"],
  "exclude": ["node_modules"]
}
