<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <title>Nuevo Partido Ping Pong</title>
</head>

<body>
  <h1>Registrar un nuevo partido</h1>
  <form action="/matches" method="POST">
    <label for="player1">Jugador 1:</label>
    <input type="text" id="player1" name="player_1" required><br><br>

    <label for="player2">Jugador 2:</label>
    <input type="text" id="player2" name="player_2" required><br><br>

    <button type="submit">Guardar partido</button>
  </form>
</body>

</html>